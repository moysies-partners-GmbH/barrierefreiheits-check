{
  "name": "barrierefreiheits-check",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/main.js --platform=browser --target=es2020",
    "build:watch": "pnpm build --watch",
    "dev": "esbuild dev/main.ts --bundle --outfile=dev/bundle.js --platform=browser --target=es2020 --servedir=dev --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moysies-partners-GmbH/barrierefreiheits-check.git"
  },
